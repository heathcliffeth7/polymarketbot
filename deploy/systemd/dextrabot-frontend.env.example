# Copy to /etc/dextrabot/dextrabot-frontend.env
DATABASE_URL=postgres://dextrabot_app:CHANGE_ME@127.0.0.1:5432/dextrabot
BOT_CONFIG_DIR=/home/heathcliff/polymarketbot/config
AUTH_SECRET=CHANGE_ME_STRONG_SECRET_AT_LEAST_32_CHARS
CONFIG_ENCRYPTION_KEY=CHANGE_ME_BASE64_32BYTE_KEY
SYSTEMD_CONTROL_ENABLED=true
BOT_SERVICE_NAME=dextrabot

# HTTP-only deployment on server IP requires this to avoid Secure cookie enforcement.
AUTH_COOKIE_SECURE=false

# Set to `command -v node` on the host running the frontend service.
FRONTEND_NODE_BIN=/usr/bin/node
