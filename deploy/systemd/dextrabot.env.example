# Copy to /etc/dextrabot/dextrabot.env
DATABASE_URL=postgres://dextrabot_app:CHANGE_ME@127.0.0.1:5432/dextrabot
BOT_CONFIG_DIR=__DEXTRABOT_ROOT__/config
RUST_LOG=info
# Credentials are stored encrypted in config/exchange.toml.
# This key must match the key used by the frontend when saving credentials.
CONFIG_ENCRYPTION_KEY=CHANGE_ME_BASE64_32BYTE_KEY
LIVE_TRADING_ENABLED=false

# SOCKS5 proxy pool for trading/data HTTP and websocket traffic.
# Separate entries with comma, semicolon, or whitespace.
SOCKS5_PROXY_URLS=socks5h://USER:PASS@PROXY_HOST_1:PORT,socks5h://USER:PASS@PROXY_HOST_2:PORT
# Optional single SOCKS5 egress for CLOB /order submissions only.
# The bot checks Polymarket geoblock through this egress before sending orders.
ORDER_SOCKS5_PROXY_URL=socks5h://USER:PASS@ORDER_PROXY_HOST:PORT

# PTB open/close uses RTDS/Chainlink boundary snapshots by default.
# Enable only as a deliberate fallback to the Cloudflare-protected crypto-price API.
PTB_ENABLE_POLYMARKET_CRYPTO_PRICE_FALLBACK=false

# ML entry-quality shadow scoring (optional, does not change trade decisions)
ML_ENTRY_QUALITY_SHADOW_ENABLED=false
ML_ENTRY_QUALITY_PYTHON_BIN=__DEXTRABOT_ROOT__/.venv-ml-entry-quality/bin/python
ML_ENTRY_QUALITY_MODEL_DIR=artifacts/ml_entry_quality/v1
ML_ENTRY_QUALITY_SCORER=scripts/ml_entry_quality/score_payload.py
ML_ENTRY_QUALITY_TIMEOUT_MS=250

# Auto claim (optional)
POLYMARKET_ADDRESS=0xYOUR_POLYMARKET_ADDRESS
CLAIMER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
CLAIM_RPC_URL=https://polygon-rpc.com
