# Copy to /etc/dextrabot/dextrabot.env
DATABASE_URL=postgres://dextrabot_app:CHANGE_ME@127.0.0.1:5432/dextrabot
BOT_CONFIG_DIR=/home/heathcliff/polymarketbot/config
RUST_LOG=info
# Credentials are stored encrypted in config/exchange.toml.
# This key must match the key used by the frontend when saving credentials.
CONFIG_ENCRYPTION_KEY=CHANGE_ME_BASE64_32BYTE_KEY
LIVE_TRADING_ENABLED=false

# Auto claim (optional)
POLYMARKET_ADDRESS=0xYOUR_POLYMARKET_ADDRESS
CLAIMER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
CLAIM_RPC_URL=https://polygon-rpc.com
